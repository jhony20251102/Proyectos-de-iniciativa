{
  "name": "soporte-ti",
  "version": "1.2.0",
  "author": "Soporte TI Certus",
  "description": "Aplicación de soporte",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.soporte.ti",
    "productName": "Soporte TI",
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Soporte TI",
      "runAfterFinish": true,
      "include": "assets/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^26.1.1",
    "electron-builder": "^24.13.3"
  }
}